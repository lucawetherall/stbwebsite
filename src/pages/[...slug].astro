---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Prose from '../components/Prose.astro';
import Gallery from '../components/Gallery.astro';
import OrganSpec from '../components/OrganSpec.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  return pages.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, kicker, intro, gallery } = entry.data;
const showOrganSpec = entry.id === 'worship/st-barnabas-organ';
---
<Base title={title} description={description}>
  <PageHeader kicker={kicker} title={title} intro={intro} />
  <div class="wrap page-body">
    <Prose><Content /></Prose>
    {gallery && gallery.length > 0 && <Gallery images={gallery} />}
    {showOrganSpec && <OrganSpec />}
  </div>
</Base>

<style>
  .page-body { padding-top: 1rem; padding-bottom: clamp(3rem, 7vw, 6rem); }
</style>
