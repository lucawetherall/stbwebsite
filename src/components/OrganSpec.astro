---
import { organSpec, toRoman } from '../data/organSpec';
const { summary, attribution, divisions, mechanism } = organSpec;
---
<section class="organ-spec" aria-labelledby="organ-spec-heading">
  <header class="organ-spec__head">
    <p class="label">The Instrument</p>
    <h2 id="organ-spec-heading" class="organ-spec__title serif">Specification</h2>
    <p class="organ-spec__glance">
      <span>{summary.manuals}</span><span aria-hidden="true">·</span>
      <span>{summary.stops}</span><span aria-hidden="true">·</span>
      <span>{summary.builder}</span><span aria-hidden="true">·</span>
      <span>{summary.rebuild}</span>
    </p>
    <p class="organ-spec__attribution">{attribution}</p>
  </header>

  <div class="organ-spec__divisions">
    {divisions.map((div) => (
      <section class="division">
        <h3 class="division__name serif">
          <span>{div.name}</span>
          <span class="division__compass">{div.compass} · {div.compassNotes} notes</span>
        </h3>
        <dl class="stops">
          {div.stops.map((s) => (
            <div class="stop">
              <dt class="stop__head">
                <span class="stop__n" aria-hidden="true">{s.n}</span>
                <span class="stop__name">{s.name}</span>
              </dt>
              <dd class="stop__detail">
                <span class="stop__pitch serif">
                  {s.feet}
                  {s.ranks && <span class="stop__ranks">{toRoman(s.ranks)}</span>}
                </span>
                {(s.composition || s.note || s.sic) && (
                  <span class="stop__meta">
                    {s.composition && <span class="stop__comp">{s.composition}</span>}
                    {s.note && <span class="stop__note">{s.note}</span>}
                    {s.sic && <span class="stop__sic">[sic]</span>}
                  </span>
                )}
              </dd>
            </div>
          ))}
        </dl>
        {div.couplers && (
          <ul class="couplers">{div.couplers.map((c) => <li>{c}</li>)}</ul>
        )}
      </section>
    ))}
  </div>

  <section class="mechanism" aria-labelledby="organ-mech-heading">
    <p class="label" id="organ-mech-heading">Mechanism &amp; Accessories</p>
    <div class="mechanism__groups">
      {mechanism.map((g) => (
        <div class="mech-group">
          <h4 class="mech-group__label serif">{g.label}</h4>
          <ul class="mech-group__list">{g.items.map((i) => <li>{i}</li>)}</ul>
        </div>
      ))}
    </div>
  </section>
</section>

<style>
  /* The 2px burgundy top rule echoes the site's signature ribbon (body::before)
     and the blockquote accent — burgundy stays the single accent throughout. */
  .organ-spec {
    margin-top: clamp(3rem, 7vw, 5rem);
    padding-top: clamp(2.4rem, 5vw, 3.6rem);
    border-top: 2px solid var(--burgundy);
  }
  .organ-spec__head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .organ-spec__title {
    font-weight: 500;
    font-size: clamp(1.9rem, 3.4vw, 2.6rem);
    line-height: 1.05;
    margin-top: 0.5rem;
  }
  .organ-spec__glance {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.7rem;
    align-items: baseline;
    margin-top: 1rem;
    max-width: none;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--ink-soft);
  }
  .organ-spec__glance span[aria-hidden] { color: var(--burgundy); }
  .organ-spec__attribution {
    margin-top: 1rem;
    max-width: 64ch;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .organ-spec__divisions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.8rem 3.5rem;
    align-items: start;
  }
  @media (min-width: 720px) {
    .organ-spec__divisions { grid-template-columns: repeat(2, 1fr); }
  }

  .division__name {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    font-weight: 500;
    font-size: clamp(1.35rem, 2vw, 1.6rem);
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.8rem;
  }
  .division__compass {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--burgundy);
    white-space: nowrap;
  }

  .stops { display: grid; }
  .stop {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 1rem;
    padding: 0.3rem 0;
  }
  .stop__head {
    display: grid;
    grid-template-columns: 1.7em 1fr;
    align-items: baseline;
    column-gap: 0.45rem;
    min-width: 0;
  }
  .stop__n {
    font-size: 0.72rem;
    color: var(--ink-soft);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .stop__name { font-size: 1.05rem; line-height: 1.3; }
  .stop__detail {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 0.05rem;
  }
  .stop__pitch { font-size: 1.1rem; font-weight: 600; line-height: 1.2; white-space: nowrap; }
  .stop__ranks {
    margin-left: 0.25rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.82em;
    letter-spacing: 0.04em;
  }
  .stop__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.1rem 0.55rem;
    font-size: 0.74rem;
    color: var(--ink-soft);
  }
  .stop__comp { font-variant-numeric: tabular-nums; }
  .stop__note, .stop__sic { font-style: italic; }

  .couplers {
    list-style: none;
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 1.2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.02rem;
    color: var(--ink-soft);
  }

  .mechanism {
    margin-top: clamp(2.6rem, 5vw, 4rem);
    padding-top: 1.8rem;
    border-top: 1px solid var(--line);
  }
  .mechanism__groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem 2.5rem;
    margin-top: 1.2rem;
  }
  @media (min-width: 560px) {
    .mechanism__groups { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .mechanism__groups { grid-template-columns: repeat(4, 1fr); align-items: start; }
  }
  .mech-group__label { font-weight: 600; font-size: 1.05rem; margin-bottom: 0.5rem; }
  .mech-group__list {
    list-style: none;
    display: grid;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.45;
  }

  @media print {
    .organ-spec, .organ-spec * { color: #000 !important; }
    .organ-spec { border-top: 1.5pt solid #000; }
    .organ-spec__divisions { grid-template-columns: repeat(2, 1fr); gap: 1.2rem 2rem; }
    .division { break-inside: avoid; }
    .mechanism__groups { grid-template-columns: repeat(2, 1fr); }
  }
</style>
