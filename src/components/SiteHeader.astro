---
import Logo from './Logo.astro';
import { nav, utilityNav, type NavItem } from '../data/nav';

interface Props {
  /** Overlay the header on a hero image (white text). Otherwise a solid paper bar. */
  overlay?: boolean;
}
const { overlay = false } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const matchLen = (href: string): number => {
  if (href === '/') return path === '/' ? 0 : -1;
  return path === href || path.startsWith(href + '/') ? href.length : -1;
};
// A top-level item's strength is the longest URL match anywhere in its nav subtree, so the
// current page highlights its nav parent (e.g. Worship for /life-events), not merely its
// URL-prefix ancestor.
const subtreeMatch = (item: NavItem): number => {
  let best = matchLen(item.href);
  for (const child of item.children ?? []) {
    best = Math.max(best, matchLen(child.href));
    for (const g of child.children ?? []) best = Math.max(best, matchLen(g.href));
  }
  return best;
};
let activeTopHref: string | null = null;
let bestTop = -1;
for (const item of nav) {
  const m = subtreeMatch(item);
  if (m > bestTop) { bestTop = m; activeTopHref = item.href; }
}

const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
const isTopActive = (item: NavItem) => bestTop >= 0 && item.href === activeTopHref;
---

<header class:list={['site-header', overlay ? 'is-overlay' : 'is-solid']}>
  <div class="wrap site-header__inner">
    <a href="/" class="brand" aria-label="St Barnabas Church, Ealing — home">
      <Logo size={30} class="brand__mark" />
      <span class="brand__text">
        <span class="brand__name serif">St Barnabas Church, Ealing</span>
        <span class="brand__locality">Pitshanger Lane</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="primary-nav__list">
        {nav.map((item) => (
          <li class:list={['primary-nav__item', item.children && 'has-children']}>
            <a
              href={item.href}
              class:list={['primary-nav__link', item.cta && 'primary-nav__link--cta', isTopActive(item) && 'is-active']}
              aria-current={path === item.href ? 'page' : isTopActive(item) ? 'true' : undefined}
              aria-haspopup={item.children ? 'true' : undefined}
            >{item.label}</a>
            {item.children && (
              <div class="submenu">
                <ul class="submenu__list">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={['submenu__link', isActive(child.href) && isTopActive(item) && 'is-active']}
                        aria-current={path === child.href ? 'page' : isActive(child.href) && isTopActive(item) ? 'true' : undefined}
                      >{child.label}</a>
                      {child.children && (
                        <ul class="submenu__sublist">
                          {child.children.map((g) => (
                            <li>
                              <a
                                href={g.href}
                                class:list={['submenu__link submenu__link--nested', isActive(g.href) && isTopActive(item) && 'is-active']}
                                aria-current={path === g.href ? 'page' : isActive(g.href) && isTopActive(item) ? 'true' : undefined}
                              >{g.label}</a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <span class="nav-toggle__bars" aria-hidden="true"><span></span><span></span><span></span></span>
    </button>
  </div>
</header>

<!-- Full-screen mobile / overflow nav panel -->
<div id="mobile-nav" class="mobile-nav" hidden>
  <div class="mobile-nav__head wrap">
    <span class="brand__name serif">St Barnabas Church, Ealing</span>
    <button class="mobile-nav__close" type="button" aria-label="Close menu">&times;</button>
  </div>
  <nav class="mobile-nav__body wrap" aria-label="Full site">
    <ul class="mobile-nav__list">
      {nav.map((item) => (
        <li>
          <a href={item.href} class:list={[isTopActive(item) && 'is-active']}>{item.label}</a>
          {item.children && (
            <ul>
              {item.children.map((child) => (
                <li>
                  <a href={child.href} class:list={[isActive(child.href) && isTopActive(item) && 'is-active']}>{child.label}</a>
                  {child.children && (
                    <ul>
                      {child.children.map((g) => (
                        <li><a href={g.href} class:list={[isActive(g.href) && isTopActive(item) && 'is-active']}>{g.label}</a></li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <ul class="mobile-nav__utility">
      {utilityNav.map((u) => <li><a href={u.href}>{u.label}</a></li>)}
    </ul>
  </nav>
</div>

<style>
  .site-header { position: relative; z-index: 50; }
  .site-header.is-overlay {
    position: absolute; top: 2px; left: 0; right: 0; color: var(--white);
  }
  .site-header.is-solid {
    background: var(--paper); border-bottom: 1px solid var(--line); color: var(--ink);
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; padding-block: 1.1rem;
  }

  /* brand */
  .brand { display: inline-flex; align-items: center; gap: .7rem; text-decoration: none; color: inherit; }
  .brand__mark { flex: none; }
  .brand__text { display: flex; flex-direction: column; line-height: 1.05; }
  .brand__name { font-size: 1.32rem; font-weight: 600; letter-spacing: .005em; }
  .brand__locality {
    font-family: var(--font-display); font-style: italic; font-size: .92rem; opacity: .85;
  }

  /* desktop nav */
  .primary-nav { display: none; }
  .primary-nav__list { display: flex; align-items: center; gap: 1.35rem; list-style: none; flex-wrap: nowrap; }
  .primary-nav__item { position: relative; }
  .primary-nav__link { white-space: nowrap; }
  .primary-nav__link {
    display: inline-block; text-decoration: none; color: inherit;
    font-family: var(--font-body); text-transform: uppercase; letter-spacing: .15em;
    font-size: .68rem; padding-block: .4rem; border-bottom: 1px solid transparent;
    transition: border-color .2s, color .2s;
  }
  .primary-nav__link:hover { border-bottom-color: currentColor; }
  .primary-nav__link.is-active { border-bottom-color: var(--burgundy); }
  .is-solid .primary-nav__link.is-active:not(.primary-nav__link--cta) { color: var(--burgundy); }

  /* Give: outlined CTA button — burgundy frame, fills on hover (readable on both headers) */
  .primary-nav__link--cta {
    background: transparent;
    padding: .5rem 1.1rem; border: 1px solid var(--burgundy); border-radius: 2px;
    transition: background .2s, color .2s, border-color .2s;
  }
  .primary-nav__link--cta:hover,
  .primary-nav__link--cta.is-active {
    color: var(--white); background: var(--burgundy); border-color: var(--burgundy);
  }

  /* dropdown panels (always readable: paper ground, ink text) */
  .submenu {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(.4rem);
    min-width: 14rem; background: var(--paper); color: var(--ink);
    border: 1px solid var(--line); padding: .6rem 0; box-shadow: 0 14px 34px rgba(12,9,5,.14);
    opacity: 0; visibility: hidden; pointer-events: none; transition: opacity .18s, transform .18s;
  }
  .primary-nav__item.has-children:hover .submenu,
  .primary-nav__item.has-children:focus-within .submenu {
    opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0);
  }
  .submenu__list, .submenu__sublist { list-style: none; }
  .submenu__link {
    display: block; text-decoration: none; color: var(--ink);
    font-family: var(--font-body); font-size: .92rem; padding: .42rem 1.3rem;
    transition: color .2s, background .2s;
  }
  .submenu__link:hover { color: var(--burgundy); background: var(--paper-2); }
  .submenu__link.is-active { color: var(--burgundy); }
  .submenu__link--nested { padding-left: 2.4rem; font-size: .86rem; color: var(--ink-soft); }

  /* mobile toggle */
  .nav-toggle {
    display: inline-flex; align-items: center; gap: .55rem; background: none; border: none;
    color: inherit; padding: .35rem .2rem;
  }
  .nav-toggle__bars { display: inline-flex; flex-direction: column; gap: 4px; width: 22px; }
  .nav-toggle__bars span { display: block; height: 1.5px; background: currentColor; }
  .nav-toggle__label { color: inherit; }

  /* mobile panel */
  .mobile-nav {
    position: fixed; inset: 0; z-index: 400; background: var(--paper); color: var(--ink);
    overflow-y: auto; padding-block: 1.4rem 4rem;
  }
  .mobile-nav[hidden] { display: none; }
  .mobile-nav__head { display: flex; align-items: center; justify-content: space-between; padding-block: .4rem 1.4rem; border-bottom: 1px solid var(--line); }
  .mobile-nav__head .brand__name { font-size: 1.25rem; }
  .mobile-nav__close { background: none; border: none; font-size: 2rem; line-height: 1; color: var(--ink); padding: .2rem .5rem; }
  .mobile-nav__list, .mobile-nav__utility { list-style: none; }
  .mobile-nav__list { margin-top: 1.4rem; }
  .mobile-nav__list > li > a {
    display: block; text-decoration: none; font-family: var(--font-display);
    font-size: 1.7rem; font-weight: 600; padding: .5rem 0; color: var(--ink);
  }
  .mobile-nav__list ul { list-style: none; padding-left: 1rem; margin-bottom: .6rem; }
  .mobile-nav__list ul a {
    display: block; text-decoration: none; font-family: var(--font-body);
    font-size: 1rem; padding: .32rem 0; color: var(--ink-soft);
  }
  .mobile-nav a.is-active { color: var(--burgundy); }
  .mobile-nav__utility { margin-top: 2rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
  .mobile-nav__utility a {
    display: block; text-decoration: none; text-transform: uppercase; letter-spacing: .14em;
    font-size: .72rem; padding: .4rem 0; color: var(--ink-soft);
  }

  @media (min-width: 1024px) {
    .primary-nav { display: block; }
    .nav-toggle { display: none; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const closeBtn = document.querySelector<HTMLButtonElement>('.mobile-nav__close');

  let savedScroll = 0;
  function setOpen(open: boolean) {
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
    if (open) {
      savedScroll = window.scrollY;
      document.documentElement.style.overflow = 'hidden';
      panel.querySelector<HTMLElement>('a, button')?.focus();
    } else {
      document.documentElement.style.overflow = '';
      window.scrollTo(0, savedScroll);
      toggle.focus();
    }
  }

  toggle?.addEventListener('click', () => setOpen(!!(panel?.hidden ?? true)));
  closeBtn?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.hidden) setOpen(false);
  });
  // Close after navigating via a link in the panel
  panel?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });
</script>
