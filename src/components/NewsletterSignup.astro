---
import { site } from '../data/site';

interface Props { ground?: 'paper' | 'paper-2' }
const { ground = 'paper-2' } = Astro.props;
---
<section class:list={['newsletter', `is-${ground}`]} aria-labelledby="nl-heading">
  <div class="wrap newsletter__inner">
    <p class="label">Weekly News</p>
    <h2 id="nl-heading" class="newsletter__title serif">Keep in touch</h2>
    <p class="newsletter__body">
      Our Weekly News goes out by email every Friday — services, events and notices from the
      life of the parish. Sign up and we’ll keep you in touch.
    </p>

    <div class="newsletter__actions">
      <a class="btn btn--solid" href={site.newsletterArchive} target="_blank" rel="noopener">
        Sign up for our newsletter
      </a>
    </div>
  </div>
</section>

<style>
  .newsletter.is-paper { background: var(--paper); }
  .newsletter.is-paper-2 { background: var(--paper-2); }
  .newsletter { padding-block: clamp(2.6rem, 6vw, 4.2rem); }
  .newsletter__inner { max-width: 640px; }
  .newsletter__title { margin-top: .9rem; font-weight: 500; font-size: clamp(1.8rem, 3.6vw, 2.5rem); }
  .newsletter__body { margin-top: 1rem; color: var(--ink-soft); }
  .newsletter__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem 1.8rem; margin-top: 1.8rem; }
</style>
