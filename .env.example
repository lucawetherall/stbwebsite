# Copy to .env and fill in. All optional — the site builds without them.

# ChurchDesk public iCal feed URL for org 1901 (Calendar → share/subscribe).
# When set, upcoming events are pulled at build time and rendered natively
# on /worship/special-services. If unset, the manual `events` collection is used.
# CHURCHDESK_ICAL_URL=

# Plausible Analytics domain (privacy-friendly, cookieless). When set, the
# Plausible script is emitted on every page. Leave unset to ship no analytics tag.
# PLAUSIBLE_DOMAIN=barnabites.org
